# =============================================================================
# AEGON Enterprise Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# SUPABASE (Required — Single Source of Truth for Database, Storage, Auth)
# =============================================================================
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>
SUPABASE_JWKS_URL=https://<your-project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------
# The connection string for SQLAlchemy (must use asyncpg).
# 
# DIRECT CONNECTION (Port 5432)
# Use this when connecting over IPv6 or running locally/in environments 
# without IPv4 restrictions.
# Format: postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# SESSION POOLER (Port 6543)
# Use this in serverless environments (like Render, Vercel) or when IPv4 is required.
# Format: postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<your-project-ref>.supabase.co:5432/postgres

# =============================================================================
# REDIS (Caching — Required)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# CELERY / RABBITMQ (Background Workers — Required for Report Generation)
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# =============================================================================
# FRONTEND (Only needed for deployment configuration)
# =============================================================================
VITE_API_URL=http://localhost:8000/api/v1
