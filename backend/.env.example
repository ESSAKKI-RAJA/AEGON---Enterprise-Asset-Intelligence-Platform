# ===================================
# AEGON Backend Environment Variables
# ===================================
# Copy this file to .env and fill in your values.
#
# AEGON V5.0 — Enterprise Evaluation Edition
# This edition ships WITHOUT authentication to allow immediate evaluation.
# See README > Enterprise Authentication Roadmap for production auth setup.

# DATABASE
# Option A: SQLite (default for local dev — zero config required)
USE_SQLITE=true

# Option B: Supabase PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your-project.supabase.co:5432/postgres
# POSTGRES_SERVER=db.your-project.supabase.co
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_DB=postgres
# POSTGRES_PORT=5432
# USE_SQLITE=false

# REDIS (optional — platform degrades gracefully without it)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# RABBITMQ / CELERY (optional — only needed for background workers)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# AI / ML (optional — enables AI Copilot natural language queries)
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# EMAIL (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ENVIRONMENT
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION AUTHENTICATION (not required for evaluation edition)
# ─────────────────────────────────────────────────────────────────────────────
# Clerk (primary cloud identity — SSO, RBAC, Organizations)
# CLERK_SECRET_KEY=sk_live_your_key
# CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json
#
# Azure Active Directory (enterprise SAML/OIDC)
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
#
# Okta (workforce identity federation)
# OKTA_DOMAIN=your-domain.okta.com
# OKTA_CLIENT_ID=your-client-id
# OKTA_CLIENT_SECRET=your-client-secret
