# =============================================================================
# AEGON Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and replace the placeholders.
# Never commit .env to version control.
# =============================================================================

# SUPABASE CONFIGURATION
# The public URL and anonymous key for the Supabase project.
# These are safe to expose to the client browser.
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<SUPABASE_ANON_KEY>

# BACKEND API
# The URL pointing to the AEGON FastAPI Gateway
VITE_API_URL=http://localhost:8000/api/v1
